#!/usr/bin/env python3
"""持久化 Mac 控制器 - 使用 Unix Socket"""
import os
import sys
import json
import time
import socket
import threading
import signal

SOCKET_PATH = "/tmp/mac_control.sock"
PID_FILE = "/tmp/mac_control.pid"

sys.path.insert(0, os.path.expanduser('~/mcp-remote-macos-use/src'))
import vnc_client

class Controller:
    def __init__(self):
        self.client = None
        self.running = True
    
    def connect(self):
        if self.client:
            return True, "Already connected"
        
        self.client = vnc_client.VNCClient(
            host='localhost', port=5900, 
            username='Ymir', password='1314'
        )
        success, msg = self.client.connect()
        return success, msg
    
    def close(self):
        if self.client:
            self.client.close()
            self.client = None
    
    def screenshot(self):
        if not self.client:
            self.connect()
        screenshot = self.client.capture_screen()
        if screenshot:
            path = os.path.expanduser("~/Desktop/mac_screenshot.png")
            with open(path, "wb") as f:
                f.write(screenshot)
            return {"success": True, "path": path}
        return {"error": "截图失败"}
    
    def click(self, x, y):
        if not self.client:
            self.connect()
        self.client.send_mouse_click(int(x), int(y), button=1)
        return {"success": True}
    
    def move(self, x, y):
        if not self.client:
            self.connect()
        self.client.send_pointer_event(int(x), int(y), 0)
        return {"success": True}
    
    def type(self, text):
        if not self.client:
            self.connect()
        self.client.send_text(text)
        return {"success": True}
    
    def key(self, keycode):
        if not self.client:
            self.connect()
        self.client.send_key_event(int(keycode, 0), True)
        self.client.send_key_event(int(keycode, 0), False)
        return {"success": True}
    
    def double_click(self, x, y):
        if not self.client:
            self.connect()
        self.client.send_mouse_click(int(x), int(y), button=1, double_click=True)
        return {"success": True}

ctrl = Controller()

# 如果是守护进程模式
if len(sys.argv) > 1 and sys.argv[1] == "--daemon":
    # 写入 PID
    with open(PID_FILE, 'w') as f:
        f.write(str(os.getpid()))
    
    # 移除旧 socket
    if os.path.exists(SOCKET_PATH):
        os.unlink(SOCKET_PATH)
    
    # 创建 socket
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    server.bind(SOCKET_PATH)
    server.listen(1)
    
    # 连接一次，保持
    ctrl.connect()
    
    while ctrl.running:
        try:
            conn, _ = server.accept()
            data = conn.recv(4096).decode()
            if data:
                req = json.loads(data)
                cmd = req.get("cmd")
                args = req.get("args", [])
                
                result = {"error": "unknown"}
                
                if cmd == "screenshot":
                    result = ctrl.screenshot()
                elif cmd == "click" and len(args) >= 2:
                    result = ctrl.click(args[0], args[1])
                elif cmd == "move" and len(args) >= 2:
                    result = ctrl.move(args[0], args[1])
                elif cmd == "type" and len(args) >= 1:
                    result = ctrl.type(args[0])
                elif cmd == "key" and len(args) >= 1:
                    result = ctrl.key(args[0])
                elif cmd == "double_click" and len(args) >= 2:
                    result = ctrl.double_click(args[0], args[1])
                elif cmd == "quit":
                    ctrl.running = False
                    result = {"success": True}
                
                conn.send(json.dumps(result).encode())
            conn.close()
        except Exception as e:
            pass
    
    ctrl.close()
    server.close()
    if os.path.exists(SOCKET_PATH):
        os.unlink(SOCKET_PATH)
    if os.path.exists(PID_FILE):
        os.unlink(PID_FILE)

# 如果是客户端模式
elif len(sys.argv) > 1:
    # 发送命令到守护进程
    cmd = sys.argv[1]
    args = sys.argv[2:] if len(sys.argv) > 2 else []
    
    # 如果守护进程不存在，启动它
    if not os.path.exists(PID_FILE):
        os.system(f"{sys.argv[0]} --daemon &")
        time.sleep(2)
    
    # 连接 socket
    try:
        client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        client.connect(SOCKET_PATH)
        
        request = json.dumps({"cmd": cmd, "args": args})
        client.send(request.encode())
        
        response = client.recv(4096).decode()
        print(response)
        
        client.close()
    except Exception as e:
        print(json.dumps({"error": str(e)}))
else:
    print("用法:")
    print("  启动守护进程: macctl --daemon")
    print("  客户端: macctl <cmd> [args]")
